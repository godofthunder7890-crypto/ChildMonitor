<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ══ LOADING SECTION (item 10): shown 1.5–2s between major steps ══ -->
        <LinearLayout
            android:id="@+id/llLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:minHeight="600dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:indeterminate="true"
                android:indeterminateTint="#00E5FF"/>

            <TextView
                android:id="@+id/tvLoadingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking necessary permissions, please wait…"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="24dp"/>
        </LinearLayout>

        <!-- ══ CARD SECTION (item 10): permission overview with real state ══ -->
        <LinearLayout
            android:id="@+id/llCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"/>

        <!-- ══ STEP SECTION: sequential step-by-step UI ══ -->
        <LinearLayout
            android:id="@+id/llStep"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:minHeight="600dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step Setup"
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Setup"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnAction"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue"
                android:textSize="16sp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <!-- OEM Battery confirm checkbox — GONE by default, shown only in step 8 (item 8) -->
            <CheckBox
                android:id="@+id/cbBatteryConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I have disabled battery optimization for this app"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Already Done - Next"
                android:textSize="14sp"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </FrameLayout>
</ScrollView>
