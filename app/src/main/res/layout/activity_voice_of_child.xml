<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060612"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARDIAN EYE"
            android:textSize="18sp"
            android:textColor="#00E5FF"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send message to parent"
            android:textSize="13sp"
            android:textColor="#555577"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK MESSAGES"
            android:textSize="11sp"
            android:textColor="#00E5FF"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/quickMsgContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUSTOM MESSAGE"
            android:textSize="11sp"
            android:textColor="#00E5FF"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etCustomMessage"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Apna message likho (max 100 chars)"
            android:inputType="textMultiLine"
            android:maxLength="100"
            android:textColor="#CCCCCC"
            android:textColorHint="#444466"
            android:background="#0A0A1E"
            android:padding="12dp"
            android:gravity="top"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSendMessage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SEND MESSAGE"
            android:textColor="#000000"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvSentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
