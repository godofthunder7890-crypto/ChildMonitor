<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Official Google-style blue theme -->
    <style name="Theme.App"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorPrimaryVariant">#1557B0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#34A853</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="android:windowBackground">#F8F9FA</item>
    </style>
    <style name="Theme.App.Setup" parent="Theme.App">
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>

    <!-- Crash screen theme — always light so stack trace is readable -->
    <style name="Theme.App.Crash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/bg_page</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
